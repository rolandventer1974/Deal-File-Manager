<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100" height="100">
  <!-- Logo background circle -->
  <circle cx="50" cy="50" r="48" fill="#007bff" stroke="#0056b3" stroke-width="2"/>

  <!-- File/Document icon -->
  <g fill="white">
    <!-- Document shape -->
    <rect x="30" y="20" width="40" height="55" rx="2" ry="2"/>

    <!-- Horizontal lines (representing document lines) -->
    <line x1="35" y1="35" x2="65" y2="35" stroke="white" stroke-width="2" stroke-linecap="round"/>
    <line x1="35" y1="45" x2="65" y2="45" stroke="white" stroke-width="2" stroke-linecap="round"/>
    <line x1="35" y1="55" x2="65" y2="55" stroke="white" stroke-width="2" stroke-linecap="round"/>
    <line x1="35" y1="65" x2="55" y2="65" stroke="white" stroke-width="2" stroke-linecap="round"/>
  </g>
</svg>
