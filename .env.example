# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=deal_file_manager
DB_USER=dfm_user
DB_PASSWORD=your_secure_password

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://autoslmdealfilemanager.co.za

# API Keys for Security
API_KEY=your_secure_api_key_here
JWT_SECRET=your_jwt_secret_here

# File Upload Settings
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=/var/www/deal-file-manager/public/uploads

# Email Configuration (for notifications)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_email
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@dealfilemanager.com

# Logging
LOG_LEVEL=info
LOG_FILE=/var/www/deal-file-manager/logs/app.log

# ColdFusion Integration
CF_API_ENDPOINT=http://your-coldfusion-server/api
CF_API_TOKEN=your_coldfusion_api_token
